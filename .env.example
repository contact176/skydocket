# SkyDocket environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Supabase (required for auth + payments) ───────────────────────────────────
# Without these the app runs fully on localStorage with no payments.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (required for payments) ───────────────────────────────────────────
# Get your publishable key from https://dashboard.stripe.com/apikeys
# Use pk_test_... for development, pk_live_... for production.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
